generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  ADMIN
  MEMBER
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum ActionItemStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum ActionItemPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String?
  provider      String   @default("credentials")
  googleId      String?  @unique
  avatarUrl     String?
  emailVerified Boolean  @default(false)
  isAdmin       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions       Session[]
  codes          EmailVerificationCode[]
  passwordResets PasswordResetToken[]

  createdWorkspaces Workspace[]       @relation("WorkspaceCreator")
  workspaceMembers  WorkspaceMember[]

  ownedGoals  Goal[]       @relation("GoalOwner")
  goalUpdates GoalUpdate[]

  ownedMilestones Milestone[] @relation("MilestoneOwner")

  assignedActionItems ActionItem[] @relation("ActionItemAssignee")
  createdActionItems  ActionItem[] @relation("ActionItemCreator")

  announcements                Announcement[]         @relation("AnnouncementAuthor")
  announcementComments         AnnouncementComment[]
  announcementReactions        AnnouncementReaction[]
  auditLogs                    AuditLog[]
  notifications                Notification[]
  sentWorkspaceInvitations     WorkspaceInvitation[]  @relation("WorkspaceInvitationInviter")
  receivedWorkspaceInvitations WorkspaceInvitation[]  @relation("WorkspaceInvitationInvitee")
  preferences                  UserPreference?
}

model EmailVerificationCode {
  id        String    @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  accentColor String   @default("#7c3aed")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User              @relation("WorkspaceCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members   WorkspaceMember[]

  goals         Goal[]
  announcements Announcement[]
  actionItems   ActionItem[]
  auditLogs     AuditLog[]
  notifications Notification[]
  invitations   WorkspaceInvitation[]
  settings      WorkspaceSetting?
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Goal {
  id          String     @id @default(cuid())
  workspaceId String
  ownerId     String
  title       String
  description String?
  status      GoalStatus @default(NOT_STARTED)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner       User         @relation("GoalOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  milestones  Milestone[]
  actionItems ActionItem[]
  updates     GoalUpdate[]
}

model Milestone {
  id          String          @id @default(cuid())
  goalId      String
  ownerId     String?
  title       String
  description String?
  progress    Int             @default(0)
  status      MilestoneStatus @default(NOT_STARTED)
  dueDate     DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  goal  Goal  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  owner User? @relation("MilestoneOwner", fields: [ownerId], references: [id], onDelete: SetNull)
}

model GoalUpdate {
  id        String   @id @default(cuid())
  goalId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActionItem {
  id          String  @id @default(cuid())
  workspaceId String
  goalId      String?
  assigneeId  String?
  createdById String

  title       String
  description String?
  status      ActionItemStatus   @default(TODO)
  priority    ActionItemPriority @default(MEDIUM)
  dueDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  goal      Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)
  assignee  User?     @relation("ActionItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy User      @relation("ActionItemCreator", fields: [createdById], references: [id], onDelete: Cascade)
}

model Announcement {
  id          String   @id @default(cuid())
  workspaceId String
  authorId    String
  title       String
  content     String
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author    User      @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  comments  AnnouncementComment[]
  reactions AnnouncementReaction[]
}

model AnnouncementComment {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  content        String
  createdAt      DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnnouncementReaction {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  emoji          String
  createdAt      DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId, emoji])
}

model WorkspaceSetting {
  id                    String             @id @default(cuid())
  workspaceId           String             @unique
  allowMemberInvites    Boolean            @default(false)
  requireAdminApprovals Boolean            @default(true)
  allowPublicExports    Boolean            @default(false)
  defaultGoalStatus     GoalStatus         @default(NOT_STARTED)
  defaultActionPriority ActionItemPriority @default(MEDIUM)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String?
  userId      String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String?
  type        String
  title       String
  message     String
  link        String?
  metadata    Json?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WorkspaceInvitation {
  id          String        @id @default(cuid())
  workspaceId String
  inviterId   String
  inviteeId   String
  role        WorkspaceRole @default(MEMBER)
  status      String        @default("PENDING")
  createdAt   DateTime      @default(now())
  respondedAt DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter   User      @relation("WorkspaceInvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee   User      @relation("WorkspaceInvitationInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([workspaceId, inviteeId, status])
}

model UserPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  theme             String   @default("system")
  notifyMentions    Boolean  @default(true)
  notifyTasks       Boolean  @default(true)
  notifyRoleChanges Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
